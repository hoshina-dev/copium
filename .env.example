# --- HTTP server ---
PORT=8081

# --- Database ---
# Either set the full DSN ...
DATA_SOURCE_NAME="host=localhost user=postgres password=postgres dbname=copium port=5432 sslmode=disable"
# ... or the parts (DSN takes precedence if set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=copium
DB_SSLMODE=disable

# --- custapi (recipient resolution) ---
CUSTAPI_BASE_URL=http://localhost:8080
CUSTAPI_TIMEOUT_MS=3000

# --- Email provider ---
# One of: noop | smtp | ses | sendgrid
EMAIL_PROVIDER=noop
EMAIL_DEFAULT_FROM="Copium <no-reply@example.com>"

# SMTP (when EMAIL_PROVIDER=smtp)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false

# --- Outbox worker ---
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=10
WORKER_MAX_ATTEMPTS=5

# --- OpenTelemetry ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=copium
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
OTEL_EXPORTER_OTLP_INSECURE=true
